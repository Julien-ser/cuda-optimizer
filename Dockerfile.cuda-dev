# CUDA Development Environment Dockerfile
# This image provides a complete development environment for CUDA-accelerated PyTorch applications

FROM nvidia/cuda:11.8.0-devel-ubuntu22.04

# Set non-interactive frontend to avoid prompts during build
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# Install system dependencies and NVIDIA Nsight Systems
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-dev \
    git \
    wget \
    curl \
    build-essential \
    cmake \
    libssl-dev \
    libcurl4-openssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Install NVIDIA Nsight Systems (CLI version)
RUN apt-get update && apt-get install -y nsight-systems-cli && \
    rm -rf /var/lib/apt/lists/*

# Set up Python environment
RUN pip3 install --no-cache-dir --upgrade pip setuptools wheel

# Install PyTorch 2.0+ with CUDA 11.8 support
# Using the official PyTorch installation command
RUN pip3 install --no-cache-dir torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu118

# Install additional useful packages for development
RUN pip3 install --no-cache-dir \
    numpy \
    matplotlib \
    pandas \
    jupyter \
    ipython \
    tqdm \
    tensorboard \
    pytest \
    black \
    mypy \
    flake8 \
    pre-commit

# Set working directory
WORKDIR /workspace

# Validation: Check CUDA and PyTorch installation
# This will be run when container starts
CMD ["bash", "-c", " \
    echo '=== CUDA Environment Validation ===' && \
    nvcc --version && \
    echo '' && \
    nvidia-smi && \
    echo '' && \
    python3 -c 'import torch; print(f\"PyTorch: {torch.__version__}\"); print(f\"CUDA Available: {torch.cuda.is_available()}\"); print(f\"CUDA Version: {torch.version.cuda if torch.cuda.is_available() else \"N/A\"}")' && \
    echo '' && \
    echo 'Environment ready! You can now build and run CUDA-optimized PyTorch models.'"]
